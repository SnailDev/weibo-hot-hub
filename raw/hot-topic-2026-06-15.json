<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-type" content="text/html; charset=utf-8"/>
    <title>Sina Visitor System</title>
</head>
<body>
<span id="message"></span>
<script type="text/javascript" src="/js/visitor/mini_original.js?v=20161116"></script>
<script src="https://passport.sinaimg.cn/js/fp/1.2.1.umd.js"></script>
<script type="text/javascript">
    window.use_fp = "0" == "1"; // 忙聵炉氓聬娄茅聡聡茅聸聠猫庐戮氓陇聡忙聦聡莽潞鹿茫聙聜
    var url = url || {};
    (function () {
        this.l = function (u, c) {
            try {
                var s = document.createElement("script");
                s.type = "text/javascript";
                s[document.all ? "onreadystatechange" : "onload"] = function () {
                    if (document.all && this.readyState != "loaded" && this.readyState != "complete") {
                        return
                    }
                    this[document.all ? "onreadystatechange" : "onload"] = null;
                    this.parentNode.removeChild(this);
                    if (c) {
                        c()
                    }
                };
                s.src = u;
                document.getElementsByTagName("head")[0].appendChild(s)
            } catch (e) {
            }
        };
    }).call(url);

    var visitor_origin = function () {
        try {
            var need_restore = "0" == "1"; // 忙聵炉氓聬娄猫碌掳忙聛垄氓陇聧猫潞芦盲禄陆忙碌聛莽篓聥茫聙聜

            // 氓娄聜忙聻聹茅聹聙猫娄聛猫碌掳忙聛垄氓陇聧猫潞芦盲禄陆忙碌聛莽篓聥茂录聦氓掳聺猫炉聲盲禄聨 cookie 猫聨路氓聫聳莽聰篓忙聢路猫潞芦盲禄陆茫聙聜
            if (!need_restore || !Store.CookieHelper.get("SRF")) {

                // 猫聥楼猫聨路氓聫聳氓陇卤猫麓楼猫碌掳氓聢聸氓禄潞猫庐驴氓庐垄忙碌聛莽篓聥茫聙聜
                // 忙碌聛莽篓聥忙聣搂猫隆聦忙聴露茅聴麓猫驴聡茅聲驴茂录聢猫露聟猫驴聡 3s茂录聣茂录聦氓聢聶猫庐陇盲赂潞氓聡潞茅聰聶茫聙聜
                var error_timeout = window.setTimeout("error_back()", 5000);

                tid.get(function (tid, where, confidence) {
                    // 氓聫聳忙聦聡莽潞鹿茅隆潞氓聢漏氓庐聦忙聢聬茂录聦忙赂聟茅聶陇氓聡潞茅聰聶 timeout 茫聙聜
                    window.clearTimeout(error_timeout);
                    incarnate(tid, where, confidence);
                });
            } else {
                // 莽聰篓忙聢路猫潞芦盲禄陆氓颅聵氓聹篓茂录聦氓掳聺猫炉聲忙聛垄氓陇聧莽聰篓忙聢路猫潞芦盲禄陆茫聙聜
                restore();
            }
        } catch (e) {
            // 氓聡潞茅聰聶茫聙聜
            error_back();
        }
    };

    var visitor_gray = function () {
        var from = "weibo";
        var return_url = "https://m.weibo.cn/api/container/getIndex?containerid=231648_-_4&extparam=seat%253D1%2526position%253D%25255B%25255D%2526dgr%253D0%2526display_time%253D1650872180%2526pre_seqid%253D16508721809380183149353&luicode=10000011&lfid=231648_-_1";
        var request_id = "9b69456aa54693fb4224a38041056e50";
        var webdriver = navigator.webdriver;

        // 氓聟聢莽聰聼忙聢聬 rid茂录聦氓聠聧氓聫聭茅聙聛猫炉路忙卤聜
        generateRid(function(rid) {
            Store.DB.get("tid", function (v) {
                if (!v) {
                    v = "";
                }
                ufp.util.postData('https://' + window.location.host + '/visitor/genvisitor2', 'cb=visitor_gray_callback&ver=20250916&request_id='+request_id+'&tid=' + v + '&from=' + from + '&webdriver=' + webdriver + '&rid=' + rid + '&return_url=' + return_url, function (res) {
                    if (res) {
                        eval(res);
                    }
                });
            });
        });
    }

    // 莽聰聼忙聢聬 rid 莽職聞莽聥卢莽芦聥忙聳鹿忙鲁聲
    var generateRid = function(callback) {
        var rid = Date.now();
        var detector = window.wbBotDetector;
        if (!detector) {
            callback(rid);
            return;
        }
        try{
            detector.load({ "from": "pc-visitor" });
            detector.get({useCache:false}).then(function (result) {
                if (result.rid) {
                    rid = result.rid;
                }else{
                    rid = "error: empty";
                }
                callback(rid);
            }).catch(function (error) {
                callback("get-error:"+error);
            });
        }catch (e){
            callback("error:" + e.message);
        }
    };

    // 忙碌聛莽篓聥氓聟楼氓聫拢茫聙聜
    wload(function () {
        visitor_gray();
    });

    // 芒聙聹猫驴聰氓聸聻芒聙聺 氓聸聻猫掳聝氓聡陆忙聲掳茫聙聜
    var return_back = function (response) {

        if (response["retcode"] == 20000000) {
            back();
        } else {
            // 氓聡潞茅聰聶茫聙聜
            error_back(response["msg"]);
        }
    };

    // 猫路鲁猫陆卢氓聸聻氓聢聺氓搂聥氓聹掳氓聺聙茫聙聜
    var back = function () {

        var url = "https://m.weibo.cn/api/container/getIndex?containerid=231648_-_4&extparam=seat%253D1%2526position%253D%25255B%25255D%2526dgr%253D0%2526display_time%253D1650872180%2526pre_seqid%253D16508721809380183149353&luicode=10000011&lfid=231648_-_1";
        if (url != "none") {
            window.location.replace(url);
        }
    };

    // 猫路篓氓聼聼氓鹿驴忙聮颅茫聙聜
    var cross_domain = function (response) {

        var from = "weibo";
        var entry = "sinawap";
        if (response["retcode"] == 20000000) {

            var crossdomain_host = "none";
            if (crossdomain_host != "none") {

                var cross_domain_intr = window.location.protocol + "//" + crossdomain_host + "/visitor/visitor?a=crossdomain&cb=return_back&s=" +
                    encodeURIComponent(response["data"]["sub"]) + "&sp=" + encodeURIComponent(response["data"]["subp"]) + "&from=" + from + "&_rand=" + Math.random() + "&entry=" + entry;
                url.l(cross_domain_intr);
            } else {

                back();
            }
        } else {

            // 氓聡潞茅聰聶茫聙聜
            error_back(response["msg"]);
        }
    };

    // 猫路篓氓聼聼氓鹿驴忙聮颅茫聙聜
    var cross_domain2 = function (response) {

        var from = "weibo";
        var entry = "sinawap";
        if (response["retcode"] == 20000000) {

            var crossdomain_host = "none";
            if (crossdomain_host != "none") {

                var cross_domain_intr = window.location.protocol + "//" + crossdomain_host + "/visitor/visitor?a=crossdomain&s=" +
                    encodeURIComponent(response["data"]["sub"]) + "&sp=" + encodeURIComponent(response["data"]["subp"]) + "&from=" + from + "&_rand=" + Math.random() + "&entry=" + entry+"&url=" + encodeURIComponent("https://m.weibo.cn/api/container/getIndex?containerid=231648_-_4&extparam=seat%253D1%2526position%253D%25255B%25255D%2526dgr%253D0%2526display_time%253D1650872180%2526pre_seqid%253D16508721809380183149353&luicode=10000011&lfid=231648_-_1");
                window.location.replace(cross_domain_intr);
            } else {
                back();
            }
        } else {

            // 氓聡潞茅聰聶茫聙聜
            error_back(response["msg"]);
        }
    };

    // 盲赂潞莽聰篓忙聢路猫碌聥盲潞聢猫庐驴氓庐垄猫潞芦盲禄陆 茫聙聜
    var incarnate = function (tid, where, conficence) {

        var gen_conf = "";
        var from = "weibo";
        var incarnate_intr = "https://" + window.location.host + "/visitor/visitor?a=incarnate&t=" +
            encodeURIComponent(tid) + "&w=" + encodeURIComponent(where) + "&c=" + encodeURIComponent(conficence) +
            "&gc=" + encodeURIComponent(gen_conf) + "&cb=cross_domain&from=" + from + "&_rand=" + Math.random();
        url.l(incarnate_intr);
    };

    // 忙聛垄氓陇聧莽聰篓忙聢路盲赂垄氓陇卤莽職聞猫潞芦盲禄陆茫聙聜
    var restore = function () {

        var from = "weibo";
        var restore_intr = "https://" + window.location.host +
            "/visitor/visitor?a=restore&cb=restore_back&from=" + from + "&_rand=" + Math.random();

        url.l(restore_intr);
    };

    // 猫路篓氓聼聼忙聛垄氓陇聧盲赂垄氓陇卤莽職聞猫潞芦盲禄陆茫聙聜
    var restore_back = function (response) {

        // 猫潞芦盲禄陆忙聛垄氓陇聧忙聢聬氓聤聼猫碌掳氓鹿驴忙聮颅忙碌聛莽篓聥茂录聦氓聬娄氓聢聶猫碌掳氓聢聸氓禄潞猫庐驴氓庐垄忙碌聛莽篓聥茫聙聜
        if (response["retcode"] == 20000000) {

            var url = "https://m.weibo.cn/api/container/getIndex?containerid=231648_-_4&extparam=seat%253D1%2526position%253D%25255B%25255D%2526dgr%253D0%2526display_time%253D1650872180%2526pre_seqid%253D16508721809380183149353&luicode=10000011&lfid=231648_-_1";
            var alt = response["data"]["alt"];
            if (alt != "") {
                requrl = (url == "none") ? "" : "&url=" + encodeURIComponent(url);
                var params = "entry=sso&source=visitor_restore&type=3&alt=" + encodeURIComponent(alt) + requrl;
                window.location.replace("https://passport.weibo.com/sso/v2/login?" + params);
            } else {

                cross_domain(response);
            }
        } else if (response['retcode'] == 50111261 && isInIframe()) {
            //do nothing
        } else {

            tid.get(function (tid, where, confidence) {
                incarnate(tid, where, confidence);
            });
        }
    };

    // 氓聡潞茅聰聶忙聝聟氓聠碌猫驴聰氓聸聻莽聶禄氓陆聲茅隆碌茫聙聜
    var error_back = function (msg) {

        var url = "https://m.weibo.cn/api/container/getIndex?containerid=231648_-_4&extparam=seat%253D1%2526position%253D%25255B%25255D%2526dgr%253D0%2526display_time%253D1650872180%2526pre_seqid%253D16508721809380183149353&luicode=10000011&lfid=231648_-_1";
        var clientType = "mobile";
        if (url != "none") {

            if (url.indexOf("ssovie4c55=0") === -1) {
                url += (((url.indexOf("?") === -1) ? "?" : "&") + "ssovie4c55=0");
            }
            if (clientType == "mobile") {
                window.location.replace("https://passport.weibo.cn/signin/login?r=" + url);
            } else {
                window.location.replace("https://weibo.com/login.php");
            }
        } else {

            if (document.getElementById("message")) {
                document.getElementById("message").innerHTML = "Error occurred" + (msg ? (": " + msg) : ".");
            }
        }
    };

    var visitor_gray_callback = function (response) {
        if (response["retcode"] === 20000000) {
            var tid = response["data"]["tid"];
            Store.DB.set('tid', tid);

            var alt = response["data"]["alt"];
            if (alt !== "") {
                var url = "https://m.weibo.cn/api/container/getIndex?containerid=231648_-_4&extparam=seat%253D1%2526position%253D%25255B%25255D%2526dgr%253D0%2526display_time%253D1650872180%2526pre_seqid%253D16508721809380183149353&luicode=10000011&lfid=231648_-_1";
                requrl = (url === "none") ? "" : "&url=" + encodeURIComponent(url);
                var params = "entry=sso&source=visitor_restore&type=3&alt=" + encodeURIComponent(alt) + requrl;
                window.location.replace("https://passport.weibo.com/sso/v2/login?" + params);
            } else {
                cross_domain2(response)
            }
        }
    };

    var isInIframe = function () {
        try {
            return window.self !== window.top;
        } catch (e) {
            return true;
        }
    };

</script>
</body>
</html>